{
    "id": "the-gallery",
    "name": "The Gallery",
    "description": "Desktop-forward portfolio showcase. Oversized typography, generous whitespace, masonry gallery as the centerpiece. For fine artists, photographers, and jewelers.",
    "version": "1.0.0",
    "compile": true,
    "defaultTheme": "light",
    "responsivePriority": "desktop",
    "designScale": "editorial",
    "navStyle": "minimal",
    "heroVariant": "minimal-text",
    "galleryVariant": "masonry",
    "productGridVariant": "card",
    "slots": {
        "universal": [
            {
                "id": "hero",
                "label": "Hero",
                "required": true,
                "description": "Oversized typography hero \u2014 brand name as statement"
            },
            {
                "id": "gallery",
                "label": "Gallery",
                "required": true,
                "description": "Masonry portfolio showcase \u2014 the centerpiece"
            },
            {
                "id": "about",
                "label": "About",
                "required": true,
                "onHomepage": true,
                "description": "Artist statement and biography"
            },
            {
                "id": "contact",
                "label": "Contact",
                "required": true,
                "description": "Contact and representation info"
            }
        ],
        "common": [
            {
                "id": "newsletter",
                "label": "Newsletter",
                "required": false,
                "description": "Collector mailing list signup"
            }
        ],
        "differentiators": [
            {
                "id": "press",
                "label": "Press",
                "required": false,
                "description": "Press mentions, exhibitions, awards"
            },
            {
                "id": "events",
                "label": "Events",
                "required": false,
                "description": "Shows and exhibition schedule"
            }
        ]
    },
    "slotMapping": {
        "hero": "hero",
        "gallery": "gallery",
        "category-grid": null,
        "featured-products": null,
        "about-blurb": null,
        "about": "about",
        "events": "events",
        "process": null,
        "testimonials": null,
        "contact": "contact",
        "newsletter": "newsletter"
    },
    "homepageFlow": [
        "hero",
        "gallery",
        "about",
        "events",
        "contact"
    ],
    "navStructure": [
        {
            "id": "gallery",
            "label": "Work",
            "href": "#gallery"
        },
        {
            "id": "about",
            "label": "About",
            "href": "about.html"
        },
        {
            "id": "shop",
            "label": "Shop",
            "href": "shop.html"
        },
        {
            "id": "contact",
            "label": "Contact",
            "href": "#contact"
        }
    ],
    "pages": [
        {
            "file": "index.html",
            "label": "Home",
            "slots": [
                "hero",
                "gallery",
                "about",
                "events",
                "contact",
                "newsletter"
            ]
        },
        {
            "file": "shop.html",
            "label": "Shop",
            "slots": [
                "shop-header",
                "shop-grid"
            ]
        },
        {
            "file": "product.html",
            "label": "Product Detail",
            "slots": [
                "product-detail",
                "product-story"
            ]
        },
        {
            "file": "about.html",
            "label": "About",
            "slots": [
                "about-header",
                "about-story",
                "cta"
            ]
        },
        {
            "file": "schedule.html",
            "label": "Events",
            "slots": [
                "events-header",
                "events-list"
            ]
        },
        {
            "file": "orders.html",
            "label": "Orders",
            "slots": [
                "orders-header",
                "order-lookup"
            ]
        },
        {
            "file": "checkout.html",
            "label": "Checkout",
            "slots": [
                "checkout-flow"
            ]
        },
        {
            "file": "blog/index.html",
            "label": "Blog",
            "slots": [
                "blog-header",
                "blog-grid"
            ]
        },
        {
            "file": "blog/post.html",
            "label": "Blog Post",
            "slots": [
                "blog-post"
            ]
        }
    ],
    "colorSchemes": [
        {
