{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$CLAUDE_PROJECT_DIR/.claude/session-rules.md\" ] && cat \"$CLAUDE_PROJECT_DIR/.claude/session-rules.md\" || true",
            "timeout": 5,
            "statusMessage": "session rules"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/scripts/lint-design-tokens.js\" ] || node \"$CLAUDE_PROJECT_DIR/scripts/lint-design-tokens.js\" >&2 || exit 2",
            "timeout": 15,
            "statusMessage": "design-token lint"
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/scripts/lint-module-info.js\" ] || node \"$CLAUDE_PROJECT_DIR/scripts/lint-module-info.js\" >&2 || exit 2",
            "timeout": 10,
            "statusMessage": "module-info lint"
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/scripts/lint-rbac.js\" ] || node \"$CLAUDE_PROJECT_DIR/scripts/lint-rbac.js\" >&2 || exit 2",
            "timeout": 10,
            "statusMessage": "RBAC coverage guard"
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/scripts/lint-no-debug-pii-console.js\" ] || node \"$CLAUDE_PROJECT_DIR/scripts/lint-no-debug-pii-console.js\" >&2 || exit 2",
            "timeout": 10,
            "statusMessage": "debug/PII console ratchet"
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/scripts/lint-no-hardcoded-ids.js\" ] || node \"$CLAUDE_PROJECT_DIR/scripts/lint-no-hardcoded-ids.js\" >&2 || exit 2",
            "timeout": 10,
            "statusMessage": "hardcoded-ids ratchet"
          },
          {
            "type": "command",
            "command": "[ ! -f \"$CLAUDE_PROJECT_DIR/scripts/lint-unbounded-read.js\" ] || node \"$CLAUDE_PROJECT_DIR/scripts/lint-unbounded-read.js\" >&2 || exit 2",
            "timeout": 10,
            "statusMessage": "unbounded-read ratchet"
          }
        ]
      }
    ]
  }
}
