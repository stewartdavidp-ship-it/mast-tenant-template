{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "database.rules.json",
      "**/node_modules/**",
      ".claude/**",
      ".github/**",
      "mcp-server/**",
      "scripts/**",
      "docs/**",
      "CLAUDE.md",
      "ARCHITECTURE.md",
      ".mcp.json",
      ".env",
      ".gitignore",
      "package.json",
      "package-lock.json"
    ]
  }
}
